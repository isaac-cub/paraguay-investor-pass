---
// Block renderer for the page builder. Each item in `blocks` carries a Tina
// `_template` discriminator (plain-JSON reads) or a GraphQL `__typename`
// (Tina client reads) that selects the markup below. Markup mirrors the
// original hand-built sections 1:1 so the design is unchanged.
//
// `data-tina-field={tinaField(obj, 'field')}` stamps every editable field so
// the Tina admin can click an element on the page and open its field. When
// data comes from the plain-JSON fallback (no Tina metadata) tinaField returns
// undefined and the attribute is simply omitted — render is unaffected.
// CMS layer removed — static build. Stub keeps the (now inert) tinaField()
// call sites compiling; returns undefined so the attribute is omitted.
const tinaField = (..._args: any[]): undefined => undefined;

interface Props {
  blocks?: any[];
  faqs?: { question: string; answer: string }[];
  formspreeId?: string;
}
const { blocks = [], faqs = [], formspreeId = 'YOUR_FORM_ID' } = Astro.props;

const band = (b: any) => `band-${b.band || 'cream'}`;
const maxStyle = (max?: string, center = false) =>
  max ? `max-width:${max}${center ? ';margin-inline:auto' : ''}` : center ? 'margin-inline:auto' : undefined;

// Map the GraphQL union __typename back to the template key when `_template`
// is absent (i.e. data came from the Tina client rather than the JSON files).
const KIND: Record<string, string> = {
  PagesBlocksHero: 'hero',
  PagesBlocksSplit: 'split',
  PagesBlocksCardGrid: 'cardGrid',
  PagesBlocksFactRow: 'factRow',
  PagesBlocksLadder: 'ladder',
  PagesBlocksProjects: 'projects',
  PagesBlocksSteps: 'steps',
  PagesBlocksFaq: 'faq',
  PagesBlocksCtaBand: 'ctaBand',
  PagesBlocksForm: 'form',
};
const kindOf = (b: any) => b._template || KIND[b.__typename];
---
{blocks.map((b: any) => {
  switch (kindOf(b)) {

    case 'hero': return (
      <section class={`hero${b.bgImage ? ' hero--photo' : ''}`}>
        {b.bgImage && <img class="hero-bg" src={b.bgImage} alt={b.bgAlt || ''} data-tina-field={tinaField(b, 'bgImage')} />}
        <div class="wrap">
          {b.crumb && (
            <nav class="crumbs" aria-label="Breadcrumb"><a href="/" data-tina-field={tinaField(b, 'crumbRoot')}>{b.crumbRoot || 'Investor Pass'}</a><span>/</span><span data-tina-field={tinaField(b, 'crumb')} set:html={b.crumb}></span></nav>
          )}
          {b.eyebrow && <p class="eyebrow" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          <h1 set:html={b.h1} data-tina-field={tinaField(b, 'h1')}></h1>
          {b.lead && <p class="lead" set:html={b.lead} data-tina-field={tinaField(b, 'lead')}></p>}
          {b.ctas?.length > 0 && (
            <div class="hero-cta">
              {b.ctas.map((c: any) => (
                <a class={`btn btn--${c.variant || 'gold'}`} href={c.href} data-tina-field={tinaField(c, 'label')}>{c.label}{(c.variant || 'gold') === 'gold' && <Fragment>{' '}<span class="arr">→</span></Fragment>}</a>
              ))}
            </div>
          )}
          {b.stats?.length > 0 && (
            <div class="hero-meta">
              {b.stats.map((s: any) => (
                <div class="stat"><b data-tina-field={tinaField(s, 'value')}>{s.value}</b><span set:html={s.label} data-tina-field={tinaField(s, 'label')}></span></div>
              ))}
            </div>
          )}
        </div>
      </section>
    );

    case 'split': {
      const textCol = (
        <div class="reveal">
          {b.eyebrow && <p class="eyebrow" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          {b.heading && <h2 style={maxStyle(b.headingMax)} set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
          {(b.paragraphs || []).map((p: any) => <p set:html={p.text} data-tina-field={tinaField(p, 'text')}></p>)}
          {b.lawcite && (
            <div class="lawcite" style="margin-top:1.6rem"><p class="law-k" data-tina-field={tinaField(b.lawcite, 'label')}>{b.lawcite.label}</p><p set:html={b.lawcite.body} data-tina-field={tinaField(b.lawcite, 'body')}></p></div>
          )}
          {b.notice && <div class="notice" data-tina-field={tinaField(b.notice, 'body')}><b data-tina-field={tinaField(b.notice, 'title')}>{b.notice.title}</b><Fragment set:html={b.notice.body} /></div>}
          {b.table && (
            <table class="spec" style="margin-top:1.6rem">{b.table.map((r: any) => <tr><th data-tina-field={tinaField(r, 'label')}>{r.label}</th><td set:html={r.value} data-tina-field={tinaField(r, 'value')}></td></tr>)}</table>
          )}
        </div>
      );
      const asideCol = (
        <div class="reveal">
          {b.image && <img class="aside-img" src={b.image} alt={b.imageAlt || ''} loading="lazy" data-tina-field={tinaField(b, 'image')} />}
          {b.asideNoticeFirst && b.asideNotice &&<div class="notice" data-tina-field={tinaField(b.asideNotice, 'body')}><b data-tina-field={tinaField(b.asideNotice, 'title')}>{b.asideNotice.title}</b><Fragment set:html={b.asideNotice.body} /></div>}
          {b.asideTable && (
            <table class="spec" style={b.asideNoticeFirst ? 'margin-top:1.5rem' : undefined}>{b.asideTable.map((r: any) => <tr><th data-tina-field={tinaField(r, 'label')}>{r.label}</th><td set:html={r.value} data-tina-field={tinaField(r, 'value')}></td></tr>)}</table>
          )}
          {!b.asideNoticeFirst && b.asideNotice && <div class="notice" style="margin-top:1.4rem" data-tina-field={tinaField(b.asideNotice, 'body')}><b data-tina-field={tinaField(b.asideNotice, 'title')}>{b.asideNotice.title}</b><Fragment set:html={b.asideNotice.body} /></div>}
        </div>
      );
      return (
        <section class={`section ${band(b)}`}>
          <div class={`wrap ${b.reverse ? 'split--rev' : 'split'}`}>
            {b.reverse ? <>{asideCol}{textCol}</> : <>{textCol}{asideCol}</>}
          </div>
        </section>
      );
    }

    case 'factRow': return (
      <section class={`section ${band(b)}`}>
        <div class="wrap">
          {b.eyebrow && <p class="eyebrow eyebrow--center center" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          {b.heading && <h2 class="center" style={maxStyle(b.headingMax, true)} set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
          {b.lead && <p class="center lead" style={maxStyle(b.leadMax, true)} set:html={b.lead} data-tina-field={tinaField(b, 'lead')}></p>}
          <div class="factrow">
            {(b.facts || []).map((f: any) => <div class="fact reveal"><b data-tina-field={tinaField(f, 'value')}>{f.value}</b><span set:html={f.label} data-tina-field={tinaField(f, 'label')}></span></div>)}
          </div>
        </div>
      </section>
    );

    case 'cardGrid': return (
      <section class={`section ${band(b)}`}>
        <div class={`wrap${b.center ? ' center' : ''}`}>
          {b.eyebrow && <p class={`eyebrow${b.center ? ' eyebrow--center' : ''}`} data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          {b.heading && <h2 style={maxStyle(b.headingMax, b.center)} set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
          {b.lead && <p class={`lead${b.center ? ' center' : ''}`} style={maxStyle(b.leadMax, b.center)} set:html={b.lead} data-tina-field={tinaField(b, 'lead')}></p>}
          <div class="grid grid-3" style={`margin-top:2.5rem${b.center ? ';text-align:left' : ''}`}>
            {(b.cards || []).map((c: any) => (
              <div class="card reveal" data-tina-field={tinaField(c, 'title')}>{c.num && <span class="num" data-tina-field={tinaField(c, 'num')}>{c.num}</span>}<h3 set:html={c.title} data-tina-field={tinaField(c, 'title')}></h3><p set:html={c.text} data-tina-field={tinaField(c, 'text')}></p></div>
            ))}
          </div>
          {b.pull && <p class="pull" style="margin:3rem auto 0" set:html={b.pull} data-tina-field={tinaField(b, 'pull')}></p>}
        </div>
      </section>
    );

    case 'ladder': return (
      <section class={`section ${band(b)}`} id={b.id || undefined}>
        <div class="wrap">
          {b.eyebrow && <p class="eyebrow eyebrow--center center" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          {b.heading && <h2 class="center" style={maxStyle(b.headingMax, true)} set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
          {b.lead && <p class="center lead" style={maxStyle(b.leadMax, true)} set:html={b.lead} data-tina-field={tinaField(b, 'lead')}></p>}
          <nav class="ladder" aria-label="Investment routes by capital">
            {(b.rungs || []).map((r: any) => (
              <a href={r.href} data-tina-field={tinaField(r, 'title')}><span class="rung-fig" data-tina-field={tinaField(r, 'fig')}>{r.fig}</span><span class="rung-body"><b data-tina-field={tinaField(r, 'title')}>{r.title}</b><span set:html={r.text} data-tina-field={tinaField(r, 'text')}></span></span><span class="rung-go" data-tina-field={tinaField(b, 'rungCtaLabel')}>{b.rungCtaLabel || 'Explore'} →</span></a>
            ))}
          </nav>
          {b.note && <p class="form-note center" style="margin-top:1.4rem;max-width:60ch;margin-inline:auto" set:html={b.note} data-tina-field={tinaField(b, 'note')}></p>}
          {b.cta && <div class="center" style="margin-top:2.5rem"><a class="btn btn--gold" href={b.cta.href} data-tina-field={tinaField(b.cta, 'label')}>{b.cta.label}{' '}<span class="arr">→</span></a></div>}
        </div>
      </section>
    );

    case 'projects': return (
      <section class={`section ${band(b)}`}>
        <div class="wrap">
          {b.eyebrow && <p class="eyebrow" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          {b.heading && <h2 style={maxStyle(b.headingMax)} set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
          {b.lead && <p class="lead" style={maxStyle(b.leadMax)} set:html={b.lead} data-tina-field={tinaField(b, 'lead')}></p>}
          <div class="projects">
            {(b.items || []).map((p: any) => (
              <article class={`pcard reveal${p.variant === 'navy' ? ' pcard--navy' : ''}`} data-tina-field={tinaField(p, 'name')}>
                {p.image && <img class="pcard-img" src={p.image} alt={p.name} loading="lazy" data-tina-field={tinaField(p, 'image')} />}
                <div class="pcard-top"><span class="pcard-dev" data-tina-field={tinaField(p, 'developer')}>{p.developer}</span><span class="pcard-tag" data-tina-field={tinaField(p, 'location')}>{p.location}</span></div>
                <h3 set:html={p.name} data-tina-field={tinaField(p, 'name')}></h3>
                <p set:html={p.description} data-tina-field={tinaField(p, 'description')}></p>
                <div class="pcard-foot">
                  {p.ctaLabel
                    ? <a class="btn btn--gold" href={p.ctaHref || '/contact/'} style="padding:.55rem 1.1rem" data-tina-field={tinaField(p, 'ctaLabel')}>{p.ctaLabel}{' '}<span class="arr">→</span></a>
                    : <Fragment><b data-tina-field={tinaField(p, 'footMain')}>{p.footMain}</b><span data-tina-field={tinaField(p, 'footSub')}>{p.footSub}</span></Fragment>}
                </div>
              </article>
            ))}
          </div>
          {b.disclaimer && <p class="form-note" style="margin-top:1.4rem" set:html={b.disclaimer} data-tina-field={tinaField(b, 'disclaimer')}></p>}
        </div>
      </section>
    );

    case 'steps': {
      const stepsCol = (
        <div class="reveal">
          <div class="steps">
            {(b.items || []).map((s: any) => <div class="step" data-tina-field={tinaField(s, 'title')}><div><h4 set:html={s.title} data-tina-field={tinaField(s, 'title')}></h4><p set:html={s.text} data-tina-field={tinaField(s, 'text')}></p></div></div>)}
          </div>
        </div>
      );
      const textCol = (
        <div class="reveal">
          {b.eyebrow && <p class="eyebrow" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          {b.heading && <h2 style={maxStyle(b.headingMax)} set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
          {(b.paragraphs || []).map((p: any) => <p set:html={p.text} data-tina-field={tinaField(p, 'text')}></p>)}
          {b.notice && <div class="notice" data-tina-field={tinaField(b.notice, 'body')}><b data-tina-field={tinaField(b.notice, 'title')}>{b.notice.title}</b><Fragment set:html={b.notice.body} /></div>}
        </div>
      );
      const reverse = b.reverse ?? true;
      return (
        <section class={`section ${band(b)}`}>
          <div class={`wrap ${reverse ? 'split--rev' : 'split'}`}>
            {reverse ? <>{stepsCol}{textCol}</> : <>{textCol}{stepsCol}</>}
          </div>
        </section>
      );
    }

    case 'faq': {
      const items = faqs.map((f: any, i: number) => (
        <details open={i === 0} data-tina-field={tinaField(f, 'question')}>
          <summary data-tina-field={tinaField(f, 'question')}>{f.question}{' '}<span class="ic">+</span></summary>
          <div class="faq-body"><p data-tina-field={tinaField(f, 'answer')}>{f.answer}</p></div>
        </details>
      ));
      return (
        <section class={`section ${band(b)}`} id={b.id || undefined}>
          {b.wrapProse ? (
            <div class="wrap prose">
              {b.eyebrow && <p class="eyebrow" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
              {b.heading && <h2 set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
              <div class="faq">{items}</div>
            </div>
          ) : (
            <div class="wrap">
              <div class="prose">
                {b.eyebrow && <p class="eyebrow" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
                {b.heading && <h2 set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
              </div>
              <div class="faq prose">{items}</div>
            </div>
          )}
        </section>
      );
    }

    case 'ctaBand': return (
      <section class={`section band-navy cta-band${b.bgImage ? ' cta-band--photo' : ''}`}>
        {b.bgImage && <img class="cta-bg" src={b.bgImage} alt={b.bgAlt || ''} loading="lazy" data-tina-field={tinaField(b, 'bgImage')} />}
        <div class="wrap">
          {b.eyebrow && <p class="eyebrow eyebrow--center" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
          {b.pull && <p class="pull" set:html={b.pull} data-tina-field={tinaField(b, 'pull')}></p>}
          {b.lead && <p class="lead" style="max-width:48ch;margin:1.2rem auto 0" set:html={b.lead} data-tina-field={tinaField(b, 'lead')}></p>}
          {b.ctas?.length > 0 && (
            <div class="hero-cta">
              {b.ctas.map((c: any) => (
                <a class={`btn btn--${c.variant || 'gold'}`} href={c.href} data-tina-field={tinaField(c, 'label')}>{c.label}{(c.variant || 'gold') === 'gold' && <Fragment>{' '}<span class="arr">→</span></Fragment>}</a>
              ))}
            </div>
          )}
        </div>
      </section>
    );

    case 'form': return (
      <section class={`section ${band(b)}`}>
        <div class="wrap split">
          <div class="reveal">
            {b.eyebrow && <p class="eyebrow" data-tina-field={tinaField(b, 'eyebrow')}>{b.eyebrow}</p>}
            {b.heading && <h2 set:html={b.heading} data-tina-field={tinaField(b, 'heading')}></h2>}
            {(b.paragraphs || []).map((p: any) => <p set:html={p.text} data-tina-field={tinaField(p, 'text')}></p>)}
            {b.notice && <div class="notice" style="margin-top:1.4rem" data-tina-field={tinaField(b.notice, 'body')}><b data-tina-field={tinaField(b.notice, 'title')}>{b.notice.title}</b><Fragment set:html={b.notice.body} /></div>}
            {b.table && (
              <table class="spec" style="margin-top:1.6rem">{b.table.map((r: any) => <tr><th data-tina-field={tinaField(r, 'label')}>{r.label}</th><td set:html={r.value} data-tina-field={tinaField(r, 'value')}></td></tr>)}</table>
            )}
          </div>
          <div class="reveal">
            <form class="form-card" action={`https://formspree.io/f/${formspreeId}`} method="POST">
              <div class="form-grid">
                <div class="field"><label for="name">Full name</label><input type="text" id="name" name="name" autocomplete="name" required /></div>
                <div class="field"><label for="email">Email</label><input type="email" id="email" name="email" autocomplete="email" required /></div>
                <div class="field"><label for="nationality">Nationality / citizenship</label><input type="text" id="nationality" name="nationality" autocomplete="country-name" /></div>
                <div class="field">
                  <label for="route">Route of interest</label>
                  <select id="route" name="route">
                    <option value="Undecided">Undecided — advise me</option>
                    <option value="Real Estate (USD 200K)">Real Estate · USD 200K</option>
                    <option value="Financial Instruments (USD 200K)">Financial Instruments · USD 200K</option>
                    <option value="Tourism Projects (USD 150K)">Tourism Projects · USD 150K</option>
                    <option value="SUACE Company (USD 70K)">SUACE Company · USD 70K</option>
                    <option value="Film Production (USD 40K)">Film Production · USD 40K</option>
                  </select>
                </div>
                <div class="field row2">
                  <label for="networth">Approximate net worth band (optional, confidential)</label>
                  <select id="networth" name="net_worth_band">
                    <option value="Prefer not to say">Prefer not to say</option>
                    <option value="Under USD 500K">Under USD 500K</option>
                    <option value="USD 500K – 1M">USD 500K – 1M</option>
                    <option value="USD 1M – 5M">USD 1M – 5M</option>
                    <option value="USD 5M+">USD 5M+</option>
                  </select>
                </div>
                <div class="field row2">
                  <label for="message">Tell us about your situation</label>
                  <textarea id="message" name="message" placeholder="Where are you based, what are you trying to solve, and what is your timeline?"></textarea>
                </div>
              </div>
              <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
              <div class="hero-cta" style="margin-top:1.6rem"><button type="submit" class="btn btn--gold">Send enquiry <span class="arr">→</span></button></div>
              <p class="form-note">By sending this enquiry you agree to be contacted about your request. Your information is kept confidential and is never sold or shared. This form does not create a client or advisory relationship.</p>
            </form>
          </div>
        </div>
      </section>
    );

    default: return null;
  }
})}
