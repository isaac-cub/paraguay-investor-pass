---
import Base from '../layouts/Base.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import PageBody from '../components/islands/PageBody.astro';
import { islands } from '../lib/islands';
import { getPageData } from '../lib/data';
import { breadcrumb, faqPage, service } from '../lib/schema';
import { getPage, pick } from '../lib/content';

const fbTitle = 'Paraguay Real Estate Residency Route | from $200K';
const description0 =
  'Qualify for Paraguay residency with a real estate investment from USD 200,000. How the property route works, requirements and timelines. Speak to Lincoln.';

const fbFaqs = [
  { q: 'How much do I need to invest?', a: 'The real estate route requires a qualifying, income-generating property investment of at least USD 200,000.' },
  { q: 'Can foreigners own property in Paraguay?', a: 'Yes. Paraguay broadly permits foreign ownership on a passport alone, held in your name or through a properly structured vehicle. Certain border-zone and rural restrictions apply, which we screen for before any purchase.' },
  { q: 'Can I rent the property out?', a: 'Yes. The route in fact requires the property be destined to economic activity — personal or family use is excluded — so an income-generating unit is exactly what qualifies.' },
  { q: 'Is the property the same as residency?', a: 'No. The property is the qualifying investment. Residency is granted through the Investor Pass and permanent residency process; the Foreign Investor Certificate (CIE) and permanent residency are separate credentials.' },
  { q: 'Will owning property make me tax resident in Paraguay?', a: "Not automatically. Legal residency and tax residency are distinct. Paraguay's territorial system generally leaves foreign-source income untaxed locally, but your tax residency is assessed on your individual facts." },
];

const page = await getPage('real-estate');
const title = pick(page?.seoTitle, fbTitle);
const description = pick(page?.seoDescription, description0);
const ogImage = page?.ogImage ?? undefined;
const faqs = pick(page?.faqs as any[] | undefined, fbFaqs).map((f: any) => ({ question: f.question ?? f.q, answer: f.answer ?? f.a }));
const blocks = (page?.blocks as any[] | undefined) ?? [];
const pageData = await getPageData('real-estate');

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'Real Estate', path: '/real-estate/' }]),
  faqPage(faqs),
  service({ name: 'Paraguay residency through real estate investment', description, price: 200000, path: '/real-estate/' }),
];
---
<Base title={title} description={description} ogImage={ogImage} jsonld={jsonld}>
  <TinaIsland name="page" wrapper={islands.page.wrapper} params={{ slug: 'real-estate' }} primary>
    <PageBody page={pageData.data.pages} />
  </TinaIsland>
</Base>
