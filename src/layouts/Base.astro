---
import '../styles/site.css';
import Seo from '../components/Seo.astro';
import JsonLd from '../components/JsonLd.astro';
import Analytics from '../components/Analytics.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: string;
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, ogImage, type, jsonld } = Astro.props;

// Site-wide entity — injected on every page so AI/search build one consistent organisation.
const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Lincoln Global Partners',
  url: Astro.site?.href,
  description: 'Advisory on Paraguay residency by investment — the Paraguay Investor Pass.',
};
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Paraguay Investor Pass',
  url: Astro.site?.href,
};
const schemas = [organization, website, ...(Array.isArray(jsonld) ? jsonld : jsonld ? [jsonld] : [])];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <Analytics />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Cinzel:wght@500;600&family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
  <Seo title={title} description={description} ogImage={ogImage} type={type} />
  <JsonLd schema={schemas} />
</head>
<body>
  <Header />
  <slot />
  <Footer />
  <script>
    import '../scripts/site.js';
  </script>
</body>
</html>
