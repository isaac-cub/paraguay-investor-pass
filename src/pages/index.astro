---
import Base from '../layouts/Base.astro';
import Blocks from '../components/Blocks.astro';
import { faqPage } from '../lib/schema';
import { getPage, getSettings, pick } from '../lib/content';

const page = await getPage('home');
const title = pick(page?.seoTitle, 'Paraguay Residency by Investment | Investor Pass');
const description = pick(page?.seoDescription, 'Get permanent residency in Paraguay through investment from USD 70,000. Routes to residency and a path to citizenship by naturalisation. Guidance from Lincoln.');
const ogImage = page?.ogImage ?? undefined;
const faqs = ((page?.faqs as any[] | undefined) ?? []).map((f: any) => ({ question: f.question, answer: f.answer }));
const blocks = (page?.blocks as any[] | undefined) ?? [];
const settings = await getSettings();
const formspreeId = settings?.formspreeId ?? 'xojowyje';
---
<Base title={title} description={description} ogImage={ogImage} jsonld={faqPage(faqs)}>
  <Blocks blocks={blocks} faqs={faqs} formspreeId={formspreeId} />
</Base>
