---
import { getSettings, pick } from '../lib/content';
const s = await getSettings();
const path = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const nav = pick(s?.nav, [
  { href: '/', label: 'Guide' },
  { href: '/real-estate/', label: 'Real Estate' },
  { href: '/financial-instruments/', label: 'Financial' },
  { href: '/tourism/', label: 'Tourism' },
  { href: '/suace/', label: 'SUACE' },
  { href: '/film/', label: 'Film' },
  { href: '/about/', label: 'About' },
]);
const navCta = pick(s?.navCta, { href: '/contact/', label: 'Begin' });
const brandMark = pick(s?.brandMark, 'Paraguay');
const brandSmall = pick(s?.brandSmall, 'Investor Pass');
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/" aria-label="Paraguay Investor Pass — home"><b>{brandMark.toUpperCase()}</b><small>{brandSmall}</small></a>
    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
      <a class="btn btn--gold" href={navCta.href}>{navCta.label} <span class="arr">→</span></a>
    </nav>
    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </div>
</header>
