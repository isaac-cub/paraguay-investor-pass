---
import Base from '../layouts/Base.astro';
import Blocks from '../components/Blocks.astro';
import { breadcrumb } from '../lib/schema';
import { getPage, getSettings, pick } from '../lib/content';

const page = await getPage('contact');
const settings = await getSettings();
const title = pick(page?.seoTitle, 'Contact | Paraguay Investor Pass | Lincoln Partners');
const description = pick(page?.seoDescription, "Speak to Lincoln Global Partners about Paraguay residency by investment. Tell us your goals and we'll recommend the right route. Enquire today.");
const ogImage = page?.ogImage ?? undefined;
const faqs = ((page?.faqs as any[] | undefined) ?? []).map((f: any) => ({ question: f.question, answer: f.answer }));
const blocks = (page?.blocks as any[] | undefined) ?? [];
const formspreeId = pick(settings?.formspreeId, 'YOUR_FORM_ID');

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'Contact', path: '/contact/' }]),
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact — Paraguay Investor Pass',
    description,
    url: 'https://paraguayinvestorpass.com/contact/',
  },
];
---
<Base title={title} description={description} ogImage={ogImage} jsonld={jsonld}>
  <Blocks blocks={blocks} faqs={faqs} formspreeId={formspreeId} />
</Base>
