---
import Base from '../layouts/Base.astro';
import { breadcrumb, faqPage } from '../lib/schema';

const title = 'Why Paraguay: Residency, Tax & Benefits | Lincoln';
const description =
  'Why HNW families choose Paraguay: territorial tax, low cost, fast permanent residency and a path to citizenship. How the programme works, explained.';

const faqs = [
  { q: 'Is this citizenship by investment?', a: 'No — and this distinction matters. Paraguay does not sell passports. The Investor Pass grants permanent residency by investment; citizenship is obtained later, by naturalisation, after the constitutional period of residence and subject to language, civics and physical-presence requirements.' },
  { q: 'What is the territorial tax system?', a: 'Under a territorial system, income arising outside Paraguay is generally outside the scope of Paraguayan income tax. Domestic rates are a flat 10%. Legal residency and tax residency are separate questions, assessed on your individual facts.' },
  { q: 'How is an application handled?', a: 'Applications are prepared end-to-end and submitted in Paraguay, to the standard the competent authorities require, with realistic timelines stated at the outset. Where another route — or another country — would serve you better, that is said plainly.' },
];

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'About', path: '/about/' }]),
  faqPage(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'Why Paraguay — the Investor Pass programme',
    description,
    url: 'https://paraguayinvestorpass.com/about/',
  },
];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb"><a href="/">Investor Pass</a><span>/</span>About</nav>
      <p class="eyebrow">The programme</p>
      <h1>Why Paraguay: residency, tax &amp; citizenship.</h1>
      <p class="lead">One qualifying investment opens the door to permanent residency in the heart of the Southern Cone — and, in time, to a second citizenship by naturalisation. Here is what the Investor Pass is, why Paraguay is uniquely compelling, and how the path actually works.</p>
      <div class="hero-cta">
        <a class="btn btn--gold" href="/contact/">Request information <span class="arr">→</span></a>
        <a class="btn btn--ghost" href="/#routes">See the routes</a>
      </div>
      <div class="hero-meta">
        <div class="stat"><b>4</b><span>Resolution 0283/2026 routes</span></div>
        <div class="stat"><b>Territorial</b><span>Tax system</span></div>
        <div class="stat"><b>3 yrs</b><span>To citizenship eligibility</span></div>
      </div>
    </div>
  </section>

  <section class="section band-cream">
    <div class="wrap split">
      <div class="reveal">
        <p class="eyebrow">The case for Paraguay</p>
        <h2>A serious base, quietly overlooked.</h2>
        <p>Paraguay sits at the centre of the Southern Cone, bordered by Brazil and Argentina and anchored inside the <strong>Mercosur</strong> bloc. It pairs a genuinely open posture toward foreign investment with a <strong>territorial tax system</strong> — foreign-source income is generally outside the Paraguayan net, assessed on individual circumstances.</p>
        <p>For internationally minded individuals and families the appeal is straightforward: Paraguay offers one of the most capital-efficient and least bureaucratic routes to a second residency anywhere in the Americas — a real foothold in a stable, growing republic that reached investment grade with Moody's (2024) and S&amp;P (2025).</p>
        <p>The Investor Pass is the structured route in: one qualifying investment, a clear path to permanent residency, and eligibility to naturalise after the constitutional residence period.</p>
      </div>
      <div class="reveal">
        <table class="spec">
          <tr><th>Region</th><td>Southern Cone, central South America</td></tr>
          <tr><th>Bloc</th><td>Mercosur member</td></tr>
          <tr><th>Tax system</th><td>Territorial (foreign income generally untaxed)</td></tr>
          <tr><th>Legal basis</th><td>Resolution N° 0283/2026 (MIC)</td></tr>
          <tr><th>Residency</th><td>Investor Pass → permanent residency</td></tr>
          <tr><th>Citizenship</th><td>Naturalisation after 3 years' residence</td></tr>
        </table>
        <div class="notice" style="margin-top:1.4rem"><b>República del Paraguay</b>A constitutional republic at the heart of South America, with a long-standing openness to foreign investment and recognition of dual nationality in defined circumstances.</div>
      </div>
    </div>
  </section>

  <section class="section band-paper">
    <div class="wrap">
      <p class="eyebrow">How the programme works</p>
      <h2 style="max-width:20ch">Five stages, one clear sequence.</h2>
      <div class="grid grid-3" style="margin-top:2.5rem">
        <div class="card reveal"><span class="num">01</span><h3>Route selection</h3><p>Choose a qualifying route — real estate, financial instruments, approved tourism, or a SUACE company — matched to your objectives. (A separate film pathway also exists.)</p></div>
        <div class="card reveal"><span class="num">02</span><h3>Qualifying investment</h3><p>The investment is made and documented to the threshold and standard the Paraguayan authorities require.</p></div>
        <div class="card reveal"><span class="num">03</span><h3>Foreign Investor Certificate</h3><p>Once the file is complete, the MIC issues the Foreign Investor Certificate (CIE) within five business days.</p></div>
        <div class="card reveal"><span class="num">04</span><h3>Permanent residency</h3><p>The permanent residency process is progressed with Migraciones, leading to the Paraguayan cédula.</p></div>
        <div class="card reveal"><span class="num">05</span><h3>Citizenship</h3><p>After three years of permanent residence, eligibility to apply for citizenship by naturalisation — subject to the statutory requirements.</p></div>
        <div class="card reveal"><span class="num">06</span><h3>One framework</h3><p>Every route converges on the same sequence — the difference is only what you invest in, and what you hold at the end.</p></div>
      </div>
    </div>
  </section>

  <section class="section band-cream">
    <div class="wrap split--rev">
      <div class="reveal">
        <table class="spec">
          <tr><th>Handling</th><td>End-to-end, on the ground in Paraguay</td></tr>
          <tr><th>Standard</th><td>Files prepared to authority requirements</td></tr>
          <tr><th>Languages</th><td>English · Spanish · Portuguese</td></tr>
          <tr><th>Focus</th><td>Paraguay residency &amp; citizenship</td></tr>
        </table>
      </div>
      <div class="reveal">
        <p class="eyebrow">How applications are handled</p>
        <h2>Prepared properly, on the ground.</h2>
        <p>The Investor Pass is straightforward only when it is structured correctly from the first step. Applications are prepared end-to-end and submitted in Paraguay, to the standard the competent authorities require, with realistic timelines stated at the outset.</p>
        <p>Where another route — or another country — would serve an applicant better, that is said plainly. The objective is a credential that holds up, not the quickest possible sale.</p>
        <div class="notice"><b>Global standards. Local execution.</b>The two halves of every successful application — and the standard every file is held to.</div>
      </div>
    </div>
  </section>

  <section class="section band-cream">
    <div class="wrap prose"><p class="eyebrow">About the programme</p><h2>Frequently asked.</h2>
      <div class="faq">
        {faqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q} <span class="ic">+</span></summary>
            <div class="faq-body"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section band-navy cta-band">
    <div class="wrap">
      <p class="eyebrow eyebrow--center">Begin your application</p>
      <p class="pull">Residency by investment <span class="gold">in the Republic of Paraguay.</span></p>
      <div class="hero-cta"><a class="btn btn--gold" href="/contact/">Request information <span class="arr">→</span></a><a class="btn btn--ghost" href="/#routes">Explore the routes</a></div>
    </div>
  </section>
</Base>
