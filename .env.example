# Tina Cloud — hosted /admin (browser editing in production).
# Get these from tina.io → your project → Overview / Tokens.
# Local `npm run dev` works WITHOUT these; they are only needed for
# `npm run build:cms` and the hosted /admin.

NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Optional: branch Tina reads/writes. Defaults to master (or Vercel's branch).
# TINA_BRANCH=master
