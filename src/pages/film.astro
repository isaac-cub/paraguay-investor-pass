---
import Base from '../layouts/Base.astro';
import Blocks from '../components/Blocks.astro';
import RouteLinks from '../components/RouteLinks.astro';
import { breadcrumb, faqPage, service } from '../lib/schema';
import { getPage, getSettings, pick } from '../lib/content';

const page = await getPage('film');
const title = pick(page?.seoTitle, 'Paraguay Film Investment Residency | from $40K');
const description = pick(page?.seoDescription, "Paraguay's lowest-cost route: residency via a film/audiovisual contribution from USD 40,000, through a separate INAP pathway. How it works and the honest caveats. Contact Lincoln.");
const ogImage = page?.ogImage ?? undefined;
const faqs = ((page?.faqs as any[] | undefined) ?? []).map((f: any) => ({ question: f.question, answer: f.answer }));
const blocks = (page?.blocks as any[] | undefined) ?? [];

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'Film', path: '/film/' }]),
  faqPage(faqs),
  service({ name: 'Paraguay residency via film & audiovisual contribution', description, price: 40000, path: '/film/' }),
];
const settings = await getSettings();
const formspreeId = settings?.formspreeId ?? 'xojowyje';
---
<Base title={title} description={description} ogImage={ogImage} jsonld={jsonld}>
  <Blocks blocks={blocks} faqs={faqs} formspreeId={formspreeId} />
  <RouteLinks current="film" />
</Base>
