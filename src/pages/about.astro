---
import Base from '../layouts/Base.astro';
import Blocks from '../components/Blocks.astro';
import { breadcrumb, faqPage } from '../lib/schema';
import { getPage, pick } from '../lib/content';

const page = await getPage('about');
const title = pick(page?.seoTitle, 'Why Paraguay: Residency, Tax & Benefits | Lincoln');
const description = pick(page?.seoDescription, 'Why HNW families choose Paraguay: territorial tax, low cost, fast permanent residency and a path to citizenship. How the programme works, explained.');
const ogImage = page?.ogImage ?? undefined;
const faqs = ((page?.faqs as any[] | undefined) ?? []).map((f: any) => ({ question: f.question, answer: f.answer }));
const blocks = (page?.blocks as any[] | undefined) ?? [];

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'About', path: '/about/' }]),
  faqPage(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'Why Paraguay — the Investor Pass programme',
    description,
    url: 'https://paraguayinvestorpass.com/about/',
  },
];
---
<Base title={title} description={description} ogImage={ogImage} jsonld={jsonld}>
  <Blocks blocks={blocks} faqs={faqs} />
</Base>
