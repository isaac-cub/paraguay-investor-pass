---
// Editable page body rendered inside <TinaIsland>. Receives the Tina page
// document (metadata-bearing, so tinaField works in Blocks) and renders the
// existing block renderer unchanged.
import Blocks from '../Blocks.astro';

interface Props {
  page: any;
  formspreeId?: string;
}
const { page, formspreeId } = Astro.props;
const blocks = page?.blocks ?? [];
const faqs = page?.faqs ?? [];
---
<Blocks blocks={blocks} faqs={faqs} formspreeId={formspreeId} />
