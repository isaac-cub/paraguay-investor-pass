---
import Base from '../layouts/Base.astro';
import { faqPage } from '../lib/schema';
import { getPage, pick, type Faq } from '../lib/content';

const fb = {
  seoTitle: 'Paraguay Residency by Investment | Investor Pass',
  seoDescription:
    'Get permanent residency in Paraguay through investment from USD 70,000. Routes to residency and a path to citizenship by naturalisation. Guidance from Lincoln.',
  h1: 'Paraguay residency by investment.',
  heroEyebrow: 'República del Paraguay · Residency by Investment',
  heroLead:
    "A single qualifying investment grants <strong>direct permanent residency</strong> in one of South America's fastest-growing economies. Established under <strong>Resolution N° 0283/2026</strong>, the Investor Pass bypasses the temporary-residency stage entirely — with a clear pathway, in time, to citizenship by naturalisation.",
  faqs: [
    { question: 'What is the Paraguay Investor Pass?', answer: "It is Paraguay's investment-linked residency framework, established by Resolution N° 0283/2026. A qualifying investment through an approved route gives you access to the Foreign Investor Certificate (CIE) and the permanent residency process — and, after the constitutional residence period, the right to apply for citizenship by naturalisation." },
    { question: 'How much do I need to invest?', answer: "Resolution 0283/2026 sets four routes: a company capitalised through SUACE from USD 70,000, approved tourism projects from USD 150,000, real estate from USD 200,000, and financial instruments from USD 200,000. A separate, pre-existing pathway via Paraguay's audiovisual institute allows residency through a film-production contribution from approximately USD 40,000. We help you choose the route that matches your strategy, not just your budget." },
    { question: 'Is the Foreign Investor Certificate the same as residency?', answer: 'No. The MIC must issue the Foreign Investor Certificate (CIE) within five business days of a complete application, but it is a distinct investor credential. Permanent residency is a separate status granted by the migration authority, with its own process and timeline. We keep the two clearly apart — and so does the law.' },
    { question: 'When can I apply for Paraguayan citizenship?', answer: "Paraguay's Constitution (Art. 148) permits an application for naturalisation after three years of permanent residence, subject to language, civics, and physical-presence requirements, with further administrative processing time. Citizenship is granted through naturalisation — it is not conferred by the investment itself." },
    { question: 'Will Paraguay tax my worldwide income?', answer: 'Paraguay applies a territorial tax system, so income arising outside Paraguay is generally outside the scope of Paraguayan income tax. Legal residency and tax residency are separate concepts: holding an Investor Pass does not by itself determine where you are tax resident. We assess that individually, within your wider structure.' },
    { question: 'Can I include my family?', answer: 'Family members can generally be included in an Investor Pass application. The specifics depend on your circumstances and the route chosen, and are confirmed before anything is committed.' },
  ] as Faq[],
};

const page = await getPage('home');
const title = pick(page?.seoTitle, fb.seoTitle);
const description = pick(page?.seoDescription, fb.seoDescription);
const h1 = pick(page?.h1, fb.h1);
const heroEyebrow = pick(page?.heroEyebrow, fb.heroEyebrow);
const heroLead = pick(page?.heroLead, fb.heroLead);
const faqs = pick(page?.faqs as Faq[] | undefined, fb.faqs);
const ogImage = page?.ogImage ?? undefined;
---
<Base title={title} description={description} ogImage={ogImage} jsonld={faqPage(faqs)}>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">{heroEyebrow}</p>
      <h1>{h1}</h1>
      <p class="lead" set:html={heroLead}></p>
      <div class="hero-cta">
        <a class="btn btn--gold" href="#routes">Explore the options <span class="arr">→</span></a>
        <a class="btn btn--ghost" href="/contact/">Request information</a>
      </div>
      <div class="hero-meta">
        <div class="stat"><b>Direct</b><span>Permanent residency</span></div>
        <div class="stat"><b>5 days</b><span>Investor certificate (CIE)</span></div>
        <div class="stat"><b>Territorial</b><span>Tax system</span></div>
        <div class="stat"><b>Inv. grade</b><span>Moody's &amp; S&amp;P rated</span></div>
      </div>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="section band-cream">
    <div class="wrap split">
      <div class="reveal">
        <p class="eyebrow">What it is</p>
        <h2>Direct permanent residency, by investment.</h2>
        <p>The Investor Pass is Paraguay's investment-linked route to <strong>direct permanent residency</strong>. A qualifying investment is certified by the <strong>Foreign Investor Certificate</strong> — the <em>Constancia de Inversionista Extranjero</em> (CIE) — after which the permanent residency application proceeds with the national migration authority, <strong>without the usual two-year temporary stage</strong>.</p>
        <p>Citizenship is a separate, later step: after the constitutional period of residence, a permanent resident may apply for <strong>citizenship by naturalisation</strong>. It is part of the journey — but residency is the destination most investors are buying.</p>
        <div class="lawcite" style="margin-top:1.6rem">
          <p class="law-k">The law · quoted</p>
          <p>The Investor Pass is established by <strong>Resolution N° 0283/2026</strong> of Paraguay's Ministry of Industry and Commerce (MIC), signed on <strong>21 April 2026</strong> in coordination with the Dirección Nacional de Migraciones. It rebuilds the framework for the <em>Constancia de Inversionista Extranjero</em> (CIE), abrogating the earlier Resolution N° 1052/2025, and grants foreign investors direct access to permanent residency.</p>
        </div>
      </div>
      <div class="reveal">
        <div class="notice">
          <b>Read this first</b>
          Three credentials are often confused. The <strong>Foreign Investor Certificate (CIE)</strong> is a fast investor credential, issued by the MIC within five business days of a complete application. <strong>Permanent residency</strong> is a separate status granted by the migration authority, typically over several months. <strong>Citizenship</strong> comes later still, by naturalisation. They are not the same thing.
        </div>
        <table class="spec" style="margin-top:1.5rem">
          <tr><th>Programme</th><td>Investor Pass — direct permanent residency</td></tr>
          <tr><th>Legal basis</th><td>Resolution N° 0283/2026 (MIC)</td></tr>
          <tr><th>Investor certificate</th><td>CIE — issued by the MIC within ~5 business days</td></tr>
          <tr><th>Residency</th><td>Permanent, granted by Migraciones (several months)</td></tr>
          <tr><th>Maintenance</th><td>At least one visit every three years</td></tr>
          <tr><th>Tax model</th><td>Territorial — foreign-source income generally untaxed</td></tr>
        </table>
      </div>
    </div>
  </section>

  <!-- WHY PARAGUAY — ECONOMY -->
  <section class="section band-navy">
    <div class="wrap">
      <p class="eyebrow eyebrow--center center">Why Paraguay</p>
      <h2 class="center" style="max-width:20ch;margin-inline:auto">Among the fastest-growing economies in South America.</h2>
      <p class="center lead" style="max-width:58ch;margin-inline:auto">This is not a frontier bet. Paraguay reached <strong>investment grade</strong> with Moody's in 2024 (Baa3) and S&amp;P in 2025 (BBB-) — and every comparable market that crossed that line saw a decade of sustained property appreciation. The Investor Pass is simply the door in.</p>
      <div class="factrow">
        <div class="fact reveal"><b>4–5%</b><span>Average real GDP growth over the past decade — 2025 exceeded 6%</span></div>
        <div class="fact reveal"><b>Inv. grade</b><span>Upgraded by Moody's (Baa3, 2024) and S&amp;P (BBB-, 2025)</span></div>
        <div class="fact reveal"><b>10-10-10</b><span>Flat 10% corporate, personal and VAT rates</span></div>
        <div class="fact reveal"><b>Territorial</b><span>Foreign-source income generally untaxed locally</span></div>
      </div>
    </div>
  </section>

  <!-- WHY PARAGUAY — REAL ESTATE -->
  <section class="section band-cream">
    <div class="wrap split">
      <div class="reveal">
        <p class="eyebrow">The market</p>
        <h2>A property market in a once-in-a-generation phase.</h2>
        <p>Asunción's skyline is being rewritten. Paraguay's tallest building, <strong>Petra Tower</strong> (172m), topped out in 2025; <strong>Petra Imperiale</strong> is planned to reach 250m; and developers like <strong>CIVIS</strong> are delivering 50-storey towers in Las Lomas. Behind the towers is real demand in a fast-urbanising capital.</p>
        <p>For investors, the appeal is clean. Gross rental yields in Asunción typically run <strong>6–8% for residential</strong> and up to around <strong>12% for commercial or mixed-use</strong>, in USD — in a territorial, dollar-friendly system where foreigners buy freely, on a passport alone.</p>
      </div>
      <div class="reveal">
        <table class="spec">
          <tr><th>Residential yields</th><td>~6–8% gross per year, in USD</td></tr>
          <tr><th>Commercial / mixed-use</th><td>Up to ~12% gross, in USD</td></tr>
          <tr><th>Income tax</th><td>10% flat — among the lowest in the region</td></tr>
          <tr><th>Worldwide income</th><td>Not taxed (territorial system)</td></tr>
          <tr><th>Foreign ownership</th><td>Unrestricted — passport sufficient</td></tr>
          <tr><th>Currency</th><td>Stable guaraní; dollar-denominated deals common</td></tr>
        </table>
        <div class="notice" style="margin-top:1.4rem"><b>The real estate route</b>Acquiring qualifying income-generating property from USD 200,000 satisfies the Investor Pass real estate track — see the developers and projects on the Real Estate page.</div>
      </div>
    </div>
  </section>

  <!-- THE ROUTES (LADDER) -->
  <section class="section band-navy" id="routes">
    <div class="wrap">
      <p class="eyebrow eyebrow--center center">The investment options</p>
      <h2 class="center" style="max-width:18ch;margin-inline:auto">Choose the route that fits your strategy — not just your budget.</h2>
      <p class="center lead" style="max-width:52ch;margin-inline:auto">Each route leads into the same residency framework. They differ in capital, control, and what you actually own at the end.</p>

      <nav class="ladder" aria-label="Investment routes by capital">
        <a href="/real-estate/">
          <span class="rung-fig">$200K</span>
          <span class="rung-body"><b>Eligible Real Estate</b><span>Qualifying income-generating property — a tangible, appreciating asset you hold and control.</span></span>
          <span class="rung-go">Explore →</span>
        </a>
        <a href="/financial-instruments/">
          <span class="rung-fig">$200K</span>
          <span class="rung-body"><b>Financial Instruments</b><span>A qualifying financial investment held for the required period — the passive, hands-off route.</span></span>
          <span class="rung-go">Explore →</span>
        </a>
        <a href="/tourism/">
          <span class="rung-fig">$150K</span>
          <span class="rung-body"><b>Approved Touristic Projects</b><span>Investment into approved tourism developments — yield potential plus residency.</span></span>
          <span class="rung-go">Explore →</span>
        </a>
        <a href="/suace/">
          <span class="rung-fig">$70K</span>
          <span class="rung-body"><b>SUACE Business Investment</b><span>Establish and capitalise a Paraguayan company through the unified business system.</span></span>
          <span class="rung-go">Explore →</span>
        </a>
        <a href="/film/">
          <span class="rung-fig">$40K</span>
          <span class="rung-body"><b>Film Cultural Investment</b><span>A qualifying contribution to Paraguayan audiovisual production — a separate, lower-cost pathway.</span></span>
          <span class="rung-go">Explore →</span>
        </a>
      </nav>
      <p class="form-note center" style="margin-top:1.4rem;max-width:60ch;margin-inline:auto">The first four routes are the qualifying options under Resolution 0283/2026. The film contribution is a separate, pre-existing pathway via Paraguay's audiovisual institute (INAP), included here for completeness.</p>

      <div class="center" style="margin-top:2.5rem">
        <a class="btn btn--gold" href="/contact/">Request the full portfolio <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- FUNDAMENTALS -->
  <section class="section band-paper">
    <div class="wrap">
      <p class="eyebrow">The fundamentals</p>
      <h2 style="max-width:20ch">What makes the residency genuinely worth holding.</h2>
      <div class="grid grid-3" style="margin-top:2.5rem">
        <div class="card reveal"><span class="num">01</span><h3>Territorial taxation</h3><p>Income generated outside Paraguay is generally outside the scope of local income tax, and the headline rate is a flat 10%. Legal residency and tax residency remain separate questions — but the underlying model is among the most rational in the region.</p></div>
        <div class="card reveal"><span class="num">02</span><h3>Low cost of establishment</h3><p>The cost of living and doing business is a fraction of comparable jurisdictions, and qualifying property can be filed once at least 30% of the declared value is paid. Capital goes further here than almost anywhere in the Americas.</p></div>
        <div class="card reveal"><span class="num">03</span><h3>Direct, durable residency</h3><p>The Investor Pass grants permanent residency directly — no two-year temporary stage — and it is maintained with at least one visit every three years. Residency you hold, not residency you rent.</p></div>
        <div class="card reveal"><span class="num">04</span><h3>Southern Cone position</h3><p>Paraguay sits at the centre of Mercosur, bordered by Brazil and Argentina. It is the strategic anchor of a wider regional footprint — your foothold in a continent of options.</p></div>
        <div class="card reveal"><span class="num">05</span><h3>Stable and open</h3><p>A stable currency, investment-grade ratings, an open posture toward foreign investment, and recognition of dual citizenship in defined circumstances. Paraguay does not punish you for being international.</p></div>
        <div class="card reveal"><span class="num">06</span><h3>A citizenship pathway</h3><p>And, in time, optionality: after the qualifying period of permanent residence, eligibility to apply for citizenship by naturalisation. A later step — but a real one.</p></div>
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="section band-paper">
    <div class="wrap center">
      <p class="eyebrow eyebrow--center">Who the programme is for</p>
      <h2 style="max-width:22ch;margin-inline:auto">For those who want optionality before they need it.</h2>
      <div class="grid grid-3" style="margin-top:2.5rem;text-align:left">
        <div class="card reveal"><h3>The diversifier</h3><p>Americans, Europeans, and Australians who want a credible second base outside their home jurisdiction — before circumstances force the question.</p></div>
        <div class="card reveal"><h3>The entrepreneur</h3><p>Founders and operators who want a low-friction company, a territorial tax footing, and a foothold in Mercosur to build from.</p></div>
        <div class="card reveal"><h3>The citizenship-minded</h3><p>Families building deliberately toward a second passport, who understand that the strongest position is the one secured early.</p></div>
      </div>
      <p class="pull" style="margin:3rem auto 0">Optionality, <span class="gold">secured deliberately.</span></p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section band-cream" id="faq">
    <div class="wrap">
      <div class="prose">
        <p class="eyebrow">Frequently asked</p>
        <h2>Common questions, answered.</h2>
      </div>
      <div class="faq prose">
        {faqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.question} <span class="ic">+</span></summary>
            <div class="faq-body"><p>{f.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section band-navy cta-band">
    <div class="wrap">
      <p class="eyebrow eyebrow--center">Begin your application</p>
      <p class="pull">Residency by investment <span class="gold">in the Republic of Paraguay.</span></p>
      <p class="lead" style="max-width:48ch;margin:1.2rem auto 0">Request guidance on the Investor Pass and the route best suited to your circumstances.</p>
      <div class="hero-cta">
        <a class="btn btn--gold" href="/contact/">Book a consultation <span class="arr">→</span></a>
        <a class="btn btn--ghost" href="#routes">Review the routes first</a>
      </div>
    </div>
  </section>
</Base>
