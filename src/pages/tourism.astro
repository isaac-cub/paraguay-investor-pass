---
import Base from '../layouts/Base.astro';
import { breadcrumb, faqPage, service } from '../lib/schema';

const title = 'Paraguay Tourism Investment Residency | from $150K';
const description =
  'Earn Paraguay residency by investing from USD 150,000 in approved tourism projects. Eligibility, projects and the application path. Talk to Lincoln.';

const faqs = [
  { q: 'How much do I need to invest?', a: 'The tourism route requires an investment of at least USD 150,000 into an approved tourism project.' },
  { q: 'Can it generate a return?', a: 'It can. The route is built around developments that carry the potential for a project-linked return, so your qualifying capital can work while it supports your residency. Returns depend on the specific project and are never guaranteed.' },
  { q: 'What counts as an approved tourism project?', a: "Approved tourism developments are projects recognised within Paraguay's tourism framework. We curate and diligence eligible projects so your investment both qualifies for residency and stands on its own merits." },
  { q: 'Do I have to manage the project?', a: 'No. The tourism route is designed for passive participation — you invest as a stakeholder rather than operating the development yourself.' },
  { q: 'Does it lead to the same citizenship pathway?', a: 'Yes. The tourism route feeds into the same Investor Pass framework — Foreign Investor Certificate, permanent residency, and eligibility to naturalise after the constitutional residence period.' },
];

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'Tourism', path: '/tourism/' }]),
  faqPage(faqs),
  service({ name: 'Paraguay residency via approved tourism projects', description, price: 150000, path: '/tourism/' }),
];
---
<Base title={title} description={description} jsonld={jsonld}>
  <section class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb"><a href="/">Investor Pass</a><span>/</span>Touristic Projects</nav>
      <p class="eyebrow">Approved touristic projects · from USD 150,000</p>
      <h1>Paraguay residency via approved tourism projects.</h1>
      <p class="lead">Invest into an approved Paraguayan tourism project and earn your residency through capital that has the potential to return — not capital that simply sits.</p>
      <div class="hero-cta">
        <a class="btn btn--gold" href="/contact/">Start your file <span class="arr">→</span></a>
        <a class="btn btn--ghost" href="/#routes">Compare routes</a>
      </div>
      <div class="hero-meta">
        <div class="stat"><b>$150K</b><span>Minimum investment</span></div>
        <div class="stat"><b>Yield</b><span>Project-linked potential</span></div>
        <div class="stat"><b>Curated</b><span>Diligenced projects only</span></div>
      </div>
    </div>
  </section>

  <section class="section band-cream">
    <div class="wrap split">
      <div class="reveal">
        <p class="eyebrow">The route</p>
        <h2>Capital that works while it qualifies.</h2>
        <p>The tourism route lets you satisfy the Investor Pass with an investment of <strong>USD 150,000</strong> into an approved tourism development. Paraguay's tourism track exists precisely to channel foreign capital into the sector — which means your qualifying investment can carry the potential for a <strong>project-linked return</strong> rather than functioning as a sunk cost.</p>
        <p>It sits between the owned-asset certainty of real estate and the lower entry points below it: a route for investors who want their residency capital deployed into something productive, without taking on the operational weight of running a company themselves.</p>
      </div>
      <div class="reveal">
        <table class="spec">
          <tr><th>Minimum investment</th><td>USD 150,000 into an approved project</td></tr>
          <tr><th>You hold</th><td>A stake in the development</td></tr>
          <tr><th>Return</th><td>Project-linked yield potential (not guaranteed)</td></tr>
          <tr><th>Residency framework</th><td>Investor Pass → permanent residency</td></tr>
          <tr><th>Citizenship</th><td>Naturalisation after the residence period</td></tr>
          <tr><th>Best suited to</th><td>Yield-seekers and passive investors</td></tr>
        </table>
        <div class="notice" style="margin-top:1.4rem"><b>Returns are never guaranteed</b>Every project carries risk. We curate and diligence each opportunity so it stands on its own commercial merits — not only as a residency vehicle.</div>
      </div>
    </div>
  </section>

  <section class="section band-paper">
    <div class="wrap">
      <p class="eyebrow">Why this route</p>
      <h2 style="max-width:20ch">The middle ground, by design.</h2>
      <div class="grid grid-3" style="margin-top:2.5rem">
        <div class="card reveal"><span class="num">01</span><h3>Productive capital</h3><p>Your qualifying investment is deployed into a real development with the potential to generate a return.</p></div>
        <div class="card reveal"><span class="num">02</span><h3>Lower than real estate</h3><p>At USD 150,000, the tourism route sits below the property threshold while keeping your capital invested.</p></div>
        <div class="card reveal"><span class="num">03</span><h3>Passive by nature</h3><p>You participate as an investor, not an operator — no company to run, no day-to-day to manage.</p></div>
        <div class="card reveal"><span class="num">04</span><h3>Curated access</h3><p>We surface diligenced tourism projects rather than leaving you to find — and vet — them alone.</p></div>
        <div class="card reveal"><span class="num">05</span><h3>Sector tailwind</h3><p>Paraguay's tourism sector is early and under-built — exactly where considered capital tends to be rewarded.</p></div>
        <div class="card reveal"><span class="num">06</span><h3>Same destination</h3><p>The tourism route leads to the identical residency and citizenship pathway as every other route.</p></div>
      </div>
    </div>
  </section>

  <section class="section band-cream">
    <div class="wrap">
      <p class="eyebrow">Approved projects</p>
      <h2 style="max-width:24ch">Tourism developments that qualify.</h2>
      <p class="lead" style="max-width:60ch">The tourism route deploys from <strong>USD 150,000</strong> into approved tourism developments, with a business plan and periodic progress reporting. We maintain a current portfolio of diligenced, eligible projects.</p>
      <div class="projects">
        <article class="pcard reveal" style="background:var(--navy);color:var(--on-navy);border-color:var(--navy)">
          <div class="pcard-top"><span class="pcard-dev" style="color:var(--gold-bright)">The portfolio</span><span class="pcard-tag" style="color:var(--on-navy-dim);border-color:rgba(255,255,255,.2)">Updated regularly</span></div>
          <h3 style="color:#fff">Selected MIC-approved tourism projects</h3>
          <p style="color:var(--on-navy-dim)">We curate and diligence a rotating shortlist of approved tourism developments — from boutique hospitality to wellness and eco-tourism. Request the current portfolio for live availability, ticket sizes, and projected returns.</p>
          <div class="pcard-foot" style="border-color:rgba(255,255,255,.16)"><a class="btn btn--gold" href="/contact/" style="padding:.55rem 1.1rem">Request the list <span class="arr">→</span></a></div>
        </article>
        <article class="pcard reveal">
          <div class="pcard-top"><span class="pcard-dev">How we select</span><span class="pcard-tag">Diligence first</span></div>
          <h3>Commercial merit, then eligibility</h3>
          <p>Each project is screened on its own commercial standing before it is considered as a residency vehicle — approval status, developer track record, business plan, and reporting all checked.</p>
          <div class="pcard-foot"><b>From $150K</b><span>Approved tourism track</span></div>
        </article>
      </div>
      <p class="form-note" style="margin-top:1.4rem">Specific projects are shared on enquiry and are independent third-party developments. Inclusion is not an endorsement, and qualification depends on the project's approval and on meeting the tourism-track criteria. Returns are projections, not guarantees.</p>
    </div>
  </section>

  <section class="section band-cream">
    <div class="wrap prose"><p class="eyebrow">Tourism route</p><h2>Frequently asked.</h2>
      <div class="faq">
        {faqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q} <span class="ic">+</span></summary>
            <div class="faq-body"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section band-navy cta-band">
    <div class="wrap">
      <p class="eyebrow eyebrow--center">Put your capital to work</p>
      <p class="pull">Residency, with a <span class="gold">return on the side.</span></p>
      <div class="hero-cta"><a class="btn btn--gold" href="/contact/">Start your tourism file <span class="arr">→</span></a><a class="btn btn--ghost" href="/#routes">See other routes</a></div>
    </div>
  </section>
</Base>
