---
import Base from '../layouts/Base.astro';
import Blocks from '../components/Blocks.astro';
import { breadcrumb, faqPage, service } from '../lib/schema';
import { getPage, getSettings, pick } from '../lib/content';

const page = await getPage('financial-instruments');
const title = pick(page?.seoTitle, 'Paraguay Financial Instruments Residency | from $200K');
const description = pick(page?.seoDescription, 'Qualify for Paraguay residency by investing from USD 200,000 in regulated financial instruments held for two years. The passive, hands-off route. Talk to Lincoln.');
const ogImage = page?.ogImage ?? undefined;
const faqs = ((page?.faqs as any[] | undefined) ?? []).map((f: any) => ({ question: f.question, answer: f.answer }));
const blocks = (page?.blocks as any[] | undefined) ?? [];

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'Financial Instruments', path: '/financial-instruments/' }]),
  faqPage(faqs),
  service({ name: 'Paraguay residency through financial instruments', description, price: 200000, path: '/financial-instruments/' }),
];
const settings = await getSettings();
const formspreeId = settings?.formspreeId ?? 'xojowyje';
---
<Base title={title} description={description} ogImage={ogImage} jsonld={jsonld}>
  <Blocks blocks={blocks} faqs={faqs} formspreeId={formspreeId} />
</Base>
