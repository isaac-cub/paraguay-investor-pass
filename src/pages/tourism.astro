---
import Base from '../layouts/Base.astro';
import Blocks from '../components/Blocks.astro';
import { breadcrumb, faqPage, service } from '../lib/schema';
import { getPage, pick } from '../lib/content';

const page = await getPage('tourism');
const title = pick(page?.seoTitle, 'Paraguay Tourism Investment Residency | from $150K');
const description = pick(page?.seoDescription, 'Earn Paraguay residency by investing from USD 150,000 in approved tourism projects. Eligibility, projects and the application path. Talk to Lincoln.');
const ogImage = page?.ogImage ?? undefined;
const faqs = ((page?.faqs as any[] | undefined) ?? []).map((f: any) => ({ question: f.question, answer: f.answer }));
const blocks = (page?.blocks as any[] | undefined) ?? [];

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'Tourism', path: '/tourism/' }]),
  faqPage(faqs),
  service({ name: 'Paraguay residency via approved tourism projects', description, price: 150000, path: '/tourism/' }),
];
---
<Base title={title} description={description} ogImage={ogImage} jsonld={jsonld}>
  <Blocks blocks={blocks} faqs={faqs} />
</Base>
