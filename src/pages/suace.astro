---
import Base from '../layouts/Base.astro';
import Blocks from '../components/Blocks.astro';
import { breadcrumb, faqPage, service } from '../lib/schema';
import { getPage, getSettings, pick } from '../lib/content';

const page = await getPage('suace');
const title = pick(page?.seoTitle, 'SUACE Paraguay: Company Residency Route | from $70K');
const description = pick(page?.seoDescription, 'Gain Paraguay residency by forming a company via SUACE from USD 70,000. How the business route works, steps and requirements. Speak to Lincoln.');
const ogImage = page?.ogImage ?? undefined;
const faqs = ((page?.faqs as any[] | undefined) ?? []).map((f: any) => ({ question: f.question, answer: f.answer }));
const blocks = (page?.blocks as any[] | undefined) ?? [];

const jsonld = [
  breadcrumb([{ name: 'Investor Pass', path: '/' }, { name: 'SUACE', path: '/suace/' }]),
  faqPage(faqs),
  service({ name: 'Paraguay residency through SUACE company formation', description, price: 70000, path: '/suace/' }),
];
const settings = await getSettings();
const formspreeId = settings?.formspreeId ?? 'xojowyje';
---
<Base title={title} description={description} ogImage={ogImage} jsonld={jsonld}>
  <Blocks blocks={blocks} faqs={faqs} formspreeId={formspreeId} />
</Base>
